# Snowflake connection (used by backend to call Cortex Agent / write data)
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_WAREHOUSE=CLIMATE_AG_WH
SNOWFLAKE_DATABASE=CLIMATE_AG_COPILOT
SNOWFLAKE_SCHEMA=OPS
# Prefer a Programmatic Access Token (PAT) generated in Snowsight over a password
SNOWFLAKE_PAT=

# Weather data
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# App
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000
